{
    "$schema": "https://turbo.build/schema.json",
    "ui":"tui",
    "task":{
        "build":{
            "dependsOn":["^build"],
            "inputs": ["$TURBO_DEFAULT$",".env*"]
        },
        "lint":{
            "dependsOn":["^lint"]
        },
        "lint:fix":{
            "dependsOn":["^lint:fix"]
        },
        "format":{
            "dependsOn":["^format"]
        },
        "format:fix":{
            "dependsOn":["^format:fix"]
        },
        "typecheck":{
            "dependsOn":["^typecheck"]
        },
        "clean":{
            "clean":false
        },
        "dev":{
            "cache":false,
            "persistent":true
        }
    }
}